# ---- Application ----
APP_NAME=serviot-devices-api
APP_ENV=development

# Host port Nginx binds to (change if 8080 is taken locally).
NGINX_HOST_PORT=8080

# ---- Database ----
# Either set DATABASE_URL directly (wins if present)...
# DATABASE_URL=postgresql://serviot:serviot@db:5432/serviot
# ...or set the discrete parts below (used by docker-compose):
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=serviot
POSTGRES_USER=serviot
# Use a strong, unique value in every non-dev environment.
POSTGRES_PASSWORD=serviot

# ---- Connection pool ----
DB_POOL_MIN=1
DB_POOL_MAX=10
